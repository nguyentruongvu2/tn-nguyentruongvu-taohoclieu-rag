# Backend local environment (optional if using docker compose root .env)

GEMINI_API_KEY=your_real_gemini_api_key
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

COHERE_API_KEY=your_real_cohere_api_key
COHERE_RERANK_MODEL=rerank-v3.5

CHROMA_COLLECTION=rag_markdown_chunks_gem2
CHROMA_PERSIST_DIR=/app/chroma_db
LOG_LEVEL=INFO

# CORS: comma-separated list of trusted frontend origins (leave empty for dev to allow all)
# Example: ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=
