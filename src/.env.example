# Copy this file to .env and fill real keys before running docker compose
# cp .env.example .env

# Gemini (Google AI)
GEMINI_API_KEY=your_real_gemini_api_key
GEMINI_LLM_MODEL=gemini-3.1-flash-lite

# Fallback models (thử theo thứ tự khi model chính lỗi/quota/not-found)
GEMINI_LLM_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-3.5-flash

# Candidate pool (tự dò model khả dụng trong list_models nếu bật auto probe)
GEMINI_LLM_MODEL_CANDIDATES=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-3.5-flash

# Runtime behavior
GEMINI_MODEL_AUTO_PROBE=true
GEMINI_MODEL_AUTO_FAILOVER=true

# Optional deep check: sẽ gửi request generate nhỏ để test model
GEMINI_MODEL_PROBE_GENERATION=false
GEMINI_MODEL_PROBE_PROMPT=Tra loi duy nhat tu OK

GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# OCR cache (page-level) to speed up reprocess of unchanged files
OCR_CACHE_ENABLED=true
OCR_CACHE_DIR=/app/uploads/ocr_page_cache

# Cohere Rerank
COHERE_API_KEY=your_real_cohere_api_key
COHERE_RERANK_MODEL=rerank-v3.5

# Qdrant
QDRANT_COLLECTION=rag_markdown_chunks_qdrant
QDRANT_URL=http://localhost:6333

# Backend log
LOG_LEVEL=INFO

# PostgreSQL Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=rag_teaching_material
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_secure_password_2024
